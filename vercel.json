{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install && npx prisma generate",
  "crons": [
    {
      "path": "/api/cron/detect-competitive-insights",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/detect-campaigns",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/check-all-campaigns",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/cleanup-old-results",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/simulate-engagement",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/unwrap-links",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/auto-assign-unassigned",
      "schedule": "0 6,18 * * *"
    },
    {
      "path": "/api/cron/redact-names",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/check-seed-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/engage-rip-seeds",
      "schedule": "0 8,13,19 * * *"
    },
    {
      "path": "/api/cron/check-email-compliance",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/purge-old-ci-data",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/resolve-sending-providers",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/scrape-fec-launches",
      "schedule": "0 14,22 * * *"
    },
    {
      "path": "/api/cron/refresh-ballotpedia",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/digest-following",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/gsc-index",
      "schedule": "0 10 * * *"
    }
  ]
}
